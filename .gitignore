# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/

# Backups (timestamped) — these can contain old API keys / secrets
*.bak
*.bak_*
*.bak-*
*.backup_*
*.snapshot_*
backups_*/

# Database (contains user data — never commit!)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Environment & secrets
.env
.env.*
*.pem
*.key

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo
